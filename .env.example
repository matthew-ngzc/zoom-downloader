# Copy this file to `.env` for local e2e test runs.
# Do NOT commit your real `.env`.

# Public recording URL (no password/cookies required)
E2E_ZOOM_PUBLIC_URL=https://example.com/public-zoom-recording

# Password-protected recording URL
E2E_ZOOM_PROTECTED_URL=https://example.com/protected-zoom-recording

# Passcode/password for the protected recording (used by CI cookie refresh job)
E2E_ZOOM_PROTECTED_PASSCODE=example-passcode

# Base64 of full Netscape cookies.txt content for protected recording domain.
# Local e2e includes a dedicated "cookie-b64 path" test that requires this.
# Example command (PowerShell):
#   [Convert]::ToBase64String([IO.File]::ReadAllBytes(".\cookies\cookies.txt"))
E2E_ZOOM_COOKIES_TXT_B64=
